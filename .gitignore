# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs & temporary files
*.log
*.txt
*.json
!package.json
!package-lock.json
!tsconfig.json
!next.config.ts
!components.json
!*.md

# local data
/pyq/
/extracted_pyq/
# Allow PDFs/PPTXs for the app, but ignore elsewhere
# Allow ONLY top-level PDFs for the app in public/pyqs
*.pdf
*.pptx
!public/pyqs/*.pdf
!public/pyq-papers/*.pdf
# Keep subdirectories ignored to save space
public/pyqs/**/
public/pyq-papers/**/
